running_total = 0

num_of_friends = int(input("Enter the no of Friends:\n"))

appetizers = float(input("Enter the Appetizer cost:\n"))
main_courses = float(input("Enter the Main Course cost:\n"))
desserts = float(input("Enter the Desserts cost:\n"))
drinks = float(input("Enter the Drinks cost:\n"))

running_total += appetizers + main_courses + desserts + drinks
print('Total bill so far:', running_total)

tip = running_total * 0.25
print('Tip amount:', tip)

running_total += tip
print('Total with tip:', running_total)

final_bill = running_total / num_of_friends
print('Bill per person:', final_bill)

